# HTTP port for the Nest app (Next.js dev server defaults to 3000).
# Loaded by `@nestjs/config` from this file, `apps/api/.env.local`, or the monorepo root `.env`.
PORT=8080

# Origin allowed by CORS (Next.js dev).
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (matches root `docker-compose.yml`: `docker compose up -d postgres`)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=recruiter
DATABASE_PASSWORD=recruiter_dev_password
DATABASE_NAME=recruiter_screening
DATABASE_URL=postgresql://recruiter:recruiter_dev_password@localhost:5433/recruiter_screening

# JWT signing (use a long random string in production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Optional; e.g. 7d, 24h, 3600s
JWT_EXPIRES_IN=7d

# AWS S3 (presigned upload/download). For local MinIO set S3_ENDPOINT and S3_FORCE_PATH_STYLE=true.
AWS_REGION=us-east-1
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: custom endpoint (e.g. http://localhost:9000 for MinIO)
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true
