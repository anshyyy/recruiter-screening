# HTTP port for the Nest app (Next.js dev server defaults to 3000).
# Loaded by `@nestjs/config` from this file, `apps/api/.env.local`, or the monorepo root `.env`.
PORT=8080

# Origin allowed by CORS (Next.js dev).
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (matches root `docker-compose.yml`: `docker compose up -d postgres`)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=recruiter
DATABASE_PASSWORD=recruiter_dev_password
DATABASE_NAME=recruiter_screening
DATABASE_URL=postgresql://recruiter:recruiter_dev_password@localhost:5433/recruiter_screening

# JWT signing (use a long random string in production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Optional; e.g. 7d, 24h, 3600s
JWT_EXPIRES_IN=7d

# AWS S3 — `POST /uploads/file` (multipart). IAM needs s3:PutObject, s3:GetObject, s3:DeleteObject.
# Browser uses plain URLs like `https://{bucket}.s3.{region}.amazonaws.com/{hash}-{name}.pdf`.
# Résumé uploads always use object ACL `public-read`; the bucket must allow ACLs (see S3 Block Public Access / Object Ownership).
AWS_REGION=us-east-1
# Bucket: either name works
S3_BUCKET=
# AWS_S3_BUCKET=
# Credentials: omit both to use the default chain (env, profile, instance role).
# If you set one of the pair without the other, the API will fail to boot (BadRequest).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: custom endpoint (e.g. http://localhost:9000 for MinIO)
# S3_ENDPOINT=

# --- Bolna AI screening agent ---
# REST base URL (defaults to https://api.bolna.ai if unset).
BOLNA_API_BASE_URL=https://api.bolna.ai
# Endpoint path for outbound calls under the base URL. Override if your Bolna setup differs.
BOLNA_CALL_ENDPOINT=/call
# API key from the Bolna dashboard.
BOLNA_API_KEY=
# The pre-built screening agent's id (configure in Bolna; uses dynamic `{{candidate_name}}` etc. variables).
BOLNA_SCREENING_AGENT_ID=
# Webhook URL to register in the Bolna agent's Analytics tab: https://<your-host>/api/screening/webhook
# Bolna does not sign webhook requests; allow-list its source IP (13.203.39.153) at your firewall / reverse proxy.

# Pass threshold (0–1) for advancing a screened candidate to "interview". Below threshold-0.2 → "rejected".
# Same threshold gates technical interview scheduling APIs (must score >= threshold).
SCREENING_PASS_THRESHOLD=0.7
# How many times a candidate may attempt the screening call.
SCREENING_MAX_ATTEMPTS=2

# --- Technical interview scheduling (after screening pass) ---
# Web + API: JSON array of UTC ISO instants. POST /technical-interviews/confirm only accepts slots in this list.
# Voice (Bolna): If you enabled function tools (Calendar Availability, Book Appointment), those drive live
# calendar on the call. Keep this list in sync with real availability for self-serve web, or rely on voice-only.
# Example: ["2026-05-12T15:00:00.000Z","2026-05-13T16:00:00.000Z"]
TECH_INTERVIEW_AVAILABLE_SLOTS_JSON=[]
# bolna_calendar_tools | env_static | hybrid (default). Passed to Bolna as `slot_source` for your agent prompt.
# hybrid = prefer calendar tools when the candidate is unsure; env list as fallback.
TECH_INTERVIEW_SLOT_SOURCE=hybrid
# Optional separate agent for scheduling calls. If empty, the API uses BOLNA_SCREENING_AGENT_ID.
BOLNA_TECH_INTERVIEW_SCHEDULING_AGENT_ID=

# --- Optional: LLM transcript scoring (swap providers/models anytime via env — no deploy required) ---
# none | gemini | anthropic | openai
SCREENING_LLM_PROVIDER=none
# Optional: full model id (e.g. gemini-3.1-pro-preview). Omit to use built-in default.
SCREENING_LLM_MODEL=
# Gemini / Google AI Studio
GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
